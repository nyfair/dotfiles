[core]
	autocrlf = false
[user]
	name = nyfair
	email = nyfair2012@gmail.com
[color]
	diff = always
	branch = auto
	status = auto
	grep = always
[push]
	default = simple
[alias]
	a = add
	b = branch
	c = commit -m
	d = diff
	l = log
	m = merge
	o = checkout
	p = push
	r = rm -r --cached
	s = status
	t = tag
	u = pull
	e = clone
[status]
	submoduleSummary = true
[filter "lfs"]
	clean = git lfs clean %f
	smudge = git lfs smudge %f
	required = true
